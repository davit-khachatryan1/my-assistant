# =============================================================================
# Luka — environment configuration
#
# Copy this file to .env.local and fill in the keys for the providers you
# want to use. You do NOT need every key — only add keys for the chat model
# providers you actually want to work, and the ElevenLabs key if you want
# voice input/output. Anything left blank will make that feature return a
# clear "not configured" message instead of crashing.
# =============================================================================

# --- Chat providers ---
# Only needed for the ModelPicker options under each provider group.

# Anthropic Claude — enables "Claude Sonnet 5" and "Claude Haiku" in ModelPicker
# Get an API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — enables "GPT-5" and "GPT-5 Mini" in ModelPicker
# Get an API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — enables "Gemini 3 Pro" and "Gemini 3 Flash" in ModelPicker
# Get an API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# DeepSeek — enables "DeepSeek R1" and "DeepSeek V3" in ModelPicker
# Uses an OpenAI-compatible API under the hood.
# Get an API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI Grok — enables "Grok 4" and "Grok 3 Mini" in ModelPicker
# Uses an OpenAI-compatible API under the hood.
# Get an API key from: https://console.x.ai
XAI_API_KEY=

# --- Voice (speech-to-text + text-to-speech) ---
# Powers microphone transcription (ElevenLabs Scribe) AND assistant voice
# replies / voice preview in Settings (ElevenLabs TTS). One key covers both.
# Get an API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# --- Database (accounts, subscriptions, persistent conversation history) ---
# Any Postgres host works (Vercel Postgres, Neon, Supabase, etc.) — just
# needs a standard connection string.
DATABASE_URL=

# --- Auth (Auth.js v5) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# http://localhost:3000 in dev; your real domain in production
NEXTAUTH_URL=
# Resend powers magic-link sign-in emails. Get a key from https://resend.com
AUTH_RESEND_KEY=
# The verified "from" address your Resend account is allowed to send as
EMAIL_FROM=
